# Server runtime
PORT=5000
NODE_ENV=development

# URL of the client app, used for CORS
CLIENT_URL=http://localhost:5173

# Secrets used to sign JWTs — replace with long random strings (e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bowen_p2p_learning?schema=public"

# File storage driver: 'local' (default in dev, writes to /uploads) or 's3' (default in production)
STORAGE_DRIVER=local

# AWS S3 config — only required when STORAGE_DRIVER=s3
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
